PORT=3001

# Supabase — get from Project Settings → API Keys (secret key, sb_secret_...)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_secret_key

# CORS — set to your production origin (no trailing slash)
ALLOWED_ORIGIN=https://yourapp.example.com

# Paddle — get from Paddle dashboard
PADDLE_WEBHOOK_SECRET=your_webhook_secret
PADDLE_API_KEY=your_paddle_api_key
PADDLE_SANDBOX=false

# EmailJS — get from emailjs.com dashboard
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PRIVATE_KEY=your_private_key

# Transit position collector — Cloudflare R2 (S3-compatible).
# Create a bucket + R2 API token in Cloudflare Dashboard → R2.
# Collector stays disabled while these are empty.
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=urbanyx-transit
